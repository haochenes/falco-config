	cd /home/carlos/work/falco-config/cross_compile/build_ebpf/falco && $(MAKE) $(MAKESILENT) -f userspace/falco/CMakeFiles/falco_application.dir/build.make userspace/falco/CMakeFiles/falco_application.dir/versions_info.cpp.i
.PHONY : versions_info.cpp.i

versions_info.s: versions_info.cpp.s
.PHONY : versions_info.s

# target to generate assembly for a file
versions_info.cpp.s:
	cd /home/carlos/work/falco-config/cross_compile/build_ebpf/falco && $(MAKE) $(MAKESILENT) -f userspace/falco/CMakeFiles/falco_application.dir/build.make userspace/falco/CMakeFiles/falco_application.dir/versions_info.cpp.s
.PHONY : versions_info.cpp.s

